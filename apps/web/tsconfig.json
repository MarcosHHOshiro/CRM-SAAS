{
  "extends": "@crm-saas/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@crm-saas/types": [
        "../../packages/types/src/index.ts"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
