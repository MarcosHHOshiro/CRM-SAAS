{
  "info": {
    "_postman_id": "5f0b6f8a-1d9a-4c66-9ad8-0a7f9a8f7b31",
    "name": "CRM SaaS Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Authentication endpoints for the CRM SaaS API."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register succeeded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "",
                  "if (data.accessToken) {",
                  "  pm.environment.set('accessToken', data.accessToken);",
                  "}",
                  "",
                  "if (data.refreshToken) {",
                  "  pm.environment.set('refreshToken', data.refreshToken);",
                  "}",
                  "",
                  "if (data.user && data.user.id) {",
                  "  pm.environment.set('userId', data.user.id);",
                  "}",
                  "",
                  "if (data.organization && data.organization.id) {",
                  "  pm.environment.set('organizationId', data.organization.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationName\": \"{{organizationName}}\",\n  \"organizationSlug\": \"{{organizationSlug}}\",\n  \"name\": \"{{ownerName}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates the organization and owner user in a single operation."
          },
          "response": []
        },
        {
